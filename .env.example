DATABASE_URL="file:./dev.db"
ANTHROPIC_API_KEY="sk-ant-..."
NEXT_PUBLIC_WS_URL=""
WS_URL="ws://localhost:3000/ws"

# Editor mode feature flags. Set to "true" to hide the mode from the editor
# mode switcher deployment-wide (any other value, or unset, keeps it enabled).
# "view" (read-only) can never be disabled — it is the fallback every role keeps.
NEXT_PUBLIC_DISABLE_EDIT_MODE="false"
NEXT_PUBLIC_DISABLE_SUGGEST_MODE="false"
