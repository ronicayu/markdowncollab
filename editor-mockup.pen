                {
                  "type": "text",
                  "id": "ypdKk",
                  "name": "h2",
                  "fill": "#0F172A",
                  "content": "## 1. Overview",
                  "fontFamily": "JetBrains Mono",
                  "fontSize": 20,
                  "fontWeight": "600"
                },
                {
                  "type": "frame",
                  "id": "QQH5p",
                  "name": "spacer2",
                  "width": "fill_container",
                  "height": 12
                },
                {
                  "type": "text",
                  "id": "bR3M3",
                  "name": "para1",
                  "fill": "#334155",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "This document describes the REST API for the MarkdownCollab platform. All endpoints follow RESTful conventions and return JSON responses.",
                  "lineHeight": 1.6,
                  "fontFamily": "Inter",
                  "fontSize": 15
                },
                {
                  "type": "frame",
                  "id": "fO5g7",
                  "name": "spacer3",
                  "width": "fill_container",
                  "height": 8
                },
                {
                  "type": "text",
                  "id": "lbiOo",
                  "name": "para2",
                  "fill": "#334155",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "The API supports real-time collaboration through WebSocket connections and uses Yjs CRDT for conflict-free synchronization.",
                  "lineHeight": 1.6,
                  "fontFamily": "Inter",
                  "fontSize": 15
                },
                {
                  "type": "frame",
                  "id": "gpi49",
                  "name": "spacer4",
                  "width": "fill_container",
                  "height": 24
                },
                {
                  "type": "text",
                  "id": "1FSWK",
                  "name": "h2b",
                  "fill": "#0F172A",
                  "content": "## 2. Authentication",
                  "fontFamily": "JetBrains Mono",
                  "fontSize": 20,
                  "fontWeight": "600"
                },
                {
                  "type": "frame",
                  "id": "zrGuS",
                  "name": "spacer5",
                  "width": "fill_container",
                  "height": 12
                },
                {
                  "type": "text",
                  "id": "4Hn4C",
                  "name": "para3",
                  "fill": "#334155",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "All API requests require a Bearer token in the Authorization header.",
                  "lineHeight": 1.6,
                  "fontFamily": "Inter",
                  "fontSize": 15
                },
                {
                  "type": "frame",
                  "id": "YczRf",
                  "name": "spacerA",
                  "width": "fill_container",
                  "height": 4
                },
                {
                  "type": "frame",
