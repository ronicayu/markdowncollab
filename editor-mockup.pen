                    {
                      "type": "text",
                      "id": "PmQ1Y",
                      "name": "removedInline",
                      "fill": "#DC2626",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "Tokens are issued via OAuth 2.0 flow.",
                      "lineHeight": 1.6,
                      "fontFamily": "Inter",
                      "fontSize": 15
                    },
                    {
                      "type": "text",
                      "id": "EbCLo",
                      "name": "addedInline",
                      "fill": "#16A34A",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "Tokens are obtained through the OAuth 2.0 authorization code flow. See Section 2.1 for supported grant types.",
